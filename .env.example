# Optional Gemini access. Leave blank when running fully offline.
GOOGLE_API_KEY=

# Runtime profile: cpu, balanced_gpu, or paper_gpu.
HCM_AI_PROFILE=balanced_gpu

# Input dataset. Point this at the folder containing keyframes/metadata/videos.
DATA_PATH=/content/drive/MyDrive/AIC2025
# Optional legacy alias used only when DATA_PATH is unset.
AIC2025_ROOT=

# Persistent project working/output locations.
DATA_ROOT=/content/drive/MyDrive/HCM-AI-Challenge-2026/data
ARTIFACT_ROOT=/content/drive/MyDrive/HCM-AI-Challenge-2026/artifacts
OUTPUT_ROOT=/content/drive/MyDrive/HCM-AI-Challenge-2026/outputs
MODEL_CACHE=/content/drive/MyDrive/HCM-AI-Challenge-2026/model_cache

# Optional notebook locations. Change these only when your clone/Drive differs.
HCM_AI_REPO_ROOT=/content/HCM-AI-Challenge-2026
HCM_AI_DRIVE_ROOT=/content/drive/MyDrive/HCM-AI-Challenge-2026
